      <aliases enabled='yes' />
      <column datatype='integer' name='[Birth Rate (bin)]' role='dimension' type='quantitative'>
        <calculation class='bin' decimals='-3' formula='[Birth Rate]' peg='0' size='0.00374' />
      </column>
      <column datatype='real' name='[Birth Rate]' role='measure' type='quantitative' />
      <column caption='GDP Per Capita' datatype='real' default-format='c&quot;$&quot;#,##0;-&quot;$&quot;#,##0' name='[Calculation_3495640817864704]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[GDP]/[Population Total]' />
      </column>
      <column caption='Internet Usage %' datatype='real' default-format='n#,##0.00&quot;%&quot;;-#,##0.00&quot;%&quot;' name='[Calculation_3495640818221057]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Internet Usage] * 100' />
      </column>
      <column caption='Average life expectancy' datatype='real' name='[Calculation_3495640818393090]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Life Expectancy Female] + [Life Expectancy Male]) / 2' />
      </column>
      <column caption='Gender gap of life expectancy' datatype='integer' default-format='n#,##0.0&quot;yrs&quot;;-#,##0.0&quot;yrs&quot;' name='[Calculation_3495640818495491]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Life Expectancy Female] - [Life Expectancy Male]' />
      </column>
      <column caption='CO2 per capita' datatype='real' name='[Calculation_3495640818692100]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[CO2 Emissions]/[Population Total]' />
      </column>
      <column caption='Age-structure shares (0-14) %' datatype='real' name='[Calculation_3495640818757637]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Population 0-14]/[Population Total]) * 100' />
      </column>
      <column caption='Age-structure shares (15-64) %' datatype='real' name='[Calculation_3495640819015686]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Population 15-64] / [Population Total]) * 100' />
      </column>
      <column caption='Age-structure shares (65+) %' datatype='real' name='[Calculation_3495640819175431]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Population 65+]/[Population Total]) * 100' />
      </column>
      <column caption='Urban Population %' datatype='real' default-format='n#,##0.00&quot;%&quot;;-#,##0.00&quot;%&quot;' name='[Calculation_3495640856178696]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Population Urban] * 100' />
      </column>
      <column datatype='string' name='[Country/Region]' role='dimension' semantic-role='[Country].[ISO3166_2]' type='nominal' />
      <column datatype='integer' default-format='n#,##0.0&quot;yrs&quot;;-#,##0.0&quot;yrs&quot;' name='[Life Expectancy Female]' role='measure' type='quantitative' />
      <column datatype='integer' default-format='n#,##0.0&quot;yrs&quot;;-#,##0.0&quot;yrs&quot;' name='[Life Expectancy Male]' role='measure' type='quantitative' />
      <column datatype='integer' name='[Number of Records]' role='measure' type='quantitative' user:auto-column='numrec'>
